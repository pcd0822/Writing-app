# Netlify Environment Variables (template)
# - 이 파일은 Netlify가 자동 로드하지 않습니다.
# - Netlify 대시보드 > Site configuration > Environment variables에 아래 키/값을 등록하세요.
# - 값은 예시/자리표시자이므로 실제 값으로 교체해야 합니다.
#
# 로컬에서 Netlify Functions(드라이브 업로드 등)까지 쓰려면:
#   npx netlify dev
# (`npm run dev`만 쓰면 `/.netlify/functions/*`가 없어 드라이브 업로드가 실패합니다.)

## Firebase (Public - Client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

## Google Sheets + Drive (Server - Netlify Functions)
# 동일 서비스 계정으로 스프레드시트(DB)와 드라이브(과제 첨부)를 사용합니다.
# GCP 콘솔에서 해당 프로젝트에 **Google Sheets API**와 **Google Drive API**를 모두 사용 설정하세요.
#
# 드라이브 첨부: 서비스 계정은 자체 저장 용량이 없습니다. 교사가 Drive에서 폴더를 만들고
# 서비스 계정 이메일(GOOGLE_SERVICE_ACCOUNT_JSON의 client_email)을 해당 폴더에
# 「편집자」로 공유한 뒤, 앱에서 그 폴더 ID를 연결해야 업로드가 됩니다.
# 권장: 서비스 계정 JSON 전체를 한 줄로 넣기
GOOGLE_SERVICE_ACCOUNT_JSON=

# 대안(분리): 아래 2개를 사용하려면 위 JSON은 비워두세요.
GOOGLE_SA_CLIENT_EMAIL=
GOOGLE_SA_PRIVATE_KEY=

## Gemini (Server - Netlify Functions)
GEMINI_API_KEY=
# 선택. 비우면 기본 gemini-3.1-pro-preview (Google AI Studio 문서 기준 최신 플래그십 프리뷰)
GEMINI_MODEL=

